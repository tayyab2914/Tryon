# Supabase Postgres
# Project Settings -> Database -> Connection string.
# Use the "Session" pooler (port 5432) for DATABASE_URL — it works for both
# the app runtime and Prisma migrations. The "Transaction" pooler (port 6543)
# does not support prepared statements and will break Prisma migrate.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# JWT signing key — generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-string"

# Public URL used to build verification links
APP_URL="https://tryon-gold.vercel.app"

# Platform admin panel password — gates the /admin super-admin area.
# Leave blank to disable admin login entirely.
ADMIN_PASSWORD="replace-with-a-strong-secret"

# SMTP (for email verification)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@example.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_NAME="FitRoom AI"
SMTP_FROM_EMAIL="you@example.com"
# Inbox that receives "Book a demo" lead notifications (defaults to SMTP_FROM_EMAIL).
DEMO_NOTIFY_EMAIL="leads@example.com"

# Google Cloud — Vertex AI Gemini (try-on image generation).
# Service account needs the Vertex AI User role.
# GCP_SERVICE_ACCOUNT_KEY accepts the raw key JSON on one line, OR that JSON
# base64-encoded (base64 avoids quoting/newline issues in most env stores).
# USE_VERTEX=true  -> Vertex AI (service-account auth via GCP_SERVICE_ACCOUNT_KEY)
# USE_VERTEX unset -> Gemini Developer API (auth via GEMINI_API_KEY)
USE_VERTEX=true
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# gemini-3.x image models are served only from the "global" endpoint.
GOOGLE_CLOUD_LOCATION="global"
GCP_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Only needed when USE_VERTEX is not "true":
# GEMINI_API_KEY="your-gemini-api-key"
