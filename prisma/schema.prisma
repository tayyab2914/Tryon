generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  emailVerified   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Per-shopper (per-IP) try-on rate limit. Enabled by default so a single
  // visitor can't burn through a brand's generation budget.
  tryOnLimitEnabled Boolean          @default(true)
  tryOnLimitPerIp   Int              @default(5)
  tryOnLimitPeriod  TryOnLimitPeriod @default(DAILY)

  verificationTokens VerificationToken[]
  tryOns             TryOn[]
  domains            Domain[]
}

enum TryOnLimitPeriod {
  DAILY
  MONTHLY
}

model Domain {
  id         String    @id @default(cuid())
  brandId    String
  hostname   String // normalized: lowercase, no protocol/port/path
  token      String // raw token published in the DNS TXT record
  verified   Boolean   @default(false)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  brand      Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, hostname])
  @@index([hostname])
  @@index([brandId])
}

enum TryOnStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model DemoRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String
  website     String?
  catalogSize String?
  message     String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model TryOn {
  id              String      @id @default(cuid())
  brandId         String
  garment         String
  shopper         String
  status          TryOnStatus @default(PROCESSING)
  // gs:// URIs in the GCS bucket. Inputs are uploaded before the Vertex AI
  // call; resultImageUri is set once generation completes.
  personImageUri  String?
  productImageUri String?
  resultImageUri  String?
  error           String?
  // Salted SHA-256 of the shopper's IP. Used only to count try-ons per
  // shopper for the brand's IP rate limit — the raw IP is never stored.
  ipHash          String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  brand           Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([brandId, ipHash, createdAt])
}

model VerificationToken {
  id        String   @id @default(cuid())
  brandId   String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
}
